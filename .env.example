# Database Configuration
MONGODB_URI=mongodb://localhost:27017/healthflow
MONGODB_TEST_URI=mongodb://localhost:27017/healthflow-test

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRATION=7d

# Server Configuration
PORT=5000
NODE_ENV=development
LOG_LEVEL=debug

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Smartwatch/Device Configuration
DEVICE_API_TIMEOUT=5000
DEVICE_SYNC_INTERVAL=300000

# Email Configuration (Future Use)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# Compliance & Health Settings
REMINDER_CHECK_INTERVAL=60000
MISSED_REMINDER_THRESHOLD=2
HEALTH_DATA_RETENTION_DAYS=365
